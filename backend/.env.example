# PostgreSQL connection settings
# When running the backend outside of Docker, DB_HOST should be 'localhost'.
# When running the backend inside a Docker container, DB_HOST should be the name of the postgres service in your docker-compose.yml (e.g., 'db' or 'postgres').
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_NAME=your_database_name